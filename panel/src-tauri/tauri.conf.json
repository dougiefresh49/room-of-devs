{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Room",
  "version": "0.1.0",
  "identifier": "com.dougiefresh.room-panel",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Room",
        "width": 360,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}